            height: 40px;
            border-radius: 6px;
            border: 1px solid #e5e7eb;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 700;
            line-height: 1;
            box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.25);
        }

        .project-risk-legend {
            margin-top: 10px;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            background-color: #f9fafb;
            padding: 10px 12px;
            display: grid;
            gap: 6px;
        }

        .project-risk-legend-item {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            font-size: 12px;
            color: #374151;
            line-height: 1.35;
        }

        .project-risk-legend-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            margin-top: 3px;
            flex: 0 0 10px;
        }

        .project-risk-legend-text {
            flex: 1;
        }

        .project-risk-slippage-card .project-risk-legend {
            margin-top: 5px;
        }

        .financial-percentage-tile {
            grid-column: 2;
            grid-row: 1;
        }

        .financial-amount-value {
            font-size: clamp(11px, 0.9vw, 18px);
            line-height: 1.2;
            max-width: 100%;
            white-space: nowrap;
            letter-spacing: -0.01em;
            font-variant-numeric: tabular-nums;
        }

        .financial-obligation-tile {
            grid-column: 1;
            grid-row: 2;
        }

        .financial-disbursement-tile {
            grid-column: 2;
            grid-row: 2;
        }

        .financial-balance-tile {
            grid-column: 3;
            grid-row: 2;
        }

        @media (max-width: 900px) {
            .financial-metrics-layout {
                grid-template-columns: 1fr !important;
            }

            .financial-percentage-tile,
            .financial-obligation-tile,
            .financial-disbursement-tile,
            .financial-balance-tile {
                grid-column: auto;
                grid-row: auto;
            }
        }

        @media (max-width: 1100px) {
            .dashboard-top-cards {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .dashboard-status-row {
                grid-template-columns: 1fr;
            }

            .project-risk-card {
                max-width: none;
                justify-self: stretch;
            }

            .financial-status-card {
                grid-column: 1 / -1;
            }

            .dashboard-filter-grid {
                grid-template-columns: repeat(2, minmax(220px, 1fr)) !important;
            }

            .dashboard-filter-reset {
                grid-column: auto !important;
                justify-content: flex-start !important;
            }
        }

        @media (max-width: 1450px) and (min-width: 1101px) {
            .dashboard-status-row {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .dashboard-status-row > :first-child {
                grid-column: 1 / -1;
            }
        }

        @media (max-width: 700px) {
            .dashboard-top-cards {
                grid-template-columns: 1fr;
            }

            .financial-status-card {
                grid-column: auto;
            }

            .project-risk-chart {
                grid-template-columns: repeat(3, minmax(0, 1fr));
            }

            .project-risk-chart-track {
                height: 68px;
            }

            .project-risk-summary-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .project-risk-summary-value {
                font-size: 22px;
                height: 38px;
            }

            .project-update-status-grid {
                grid-template-columns: 1fr;
            }

