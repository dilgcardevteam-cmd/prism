                                $riskCount = (int) ($projectUpdateStatusCounts[$riskLabel] ?? 0);
                                $riskStyle = $projectUpdateStatusStyles[$riskLabel] ?? ['bg' => '#6b7280'];
                                $rawPercent = ($riskCount / $projectUpdateStatusTotal) * 100;
                                $startPercent = $projectUpdateStatusRunningPercent;
                                $endPercent = ($segmentIndex === $projectUpdateStatusSegmentCount - 1)
                                    ? 100.0
                                    : ($startPercent + $rawPercent);
                                $projectUpdateStatusRunningPercent = $endPercent;

                                $projectUpdateStatusPieParts[] = sprintf(
                                    '%s %.4f%% %.4f%%',
                                    $riskStyle['bg'],
                                    $startPercent,
                                    $endPercent
                                );

                                $projectUpdateStatusPieItems[] = [
                                    'label' => $riskLabel,
                                    'count' => $riskCount,
                                    'percent' => (int) round($rawPercent),
